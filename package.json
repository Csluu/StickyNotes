{
	"name": "stickynotes",
	"productName": "Sticky Notes",
	"version": "1.0.0",
	"description": "Sticky notes application",
	"main": "src/main/main.js",
	"scripts": {
		"dev": "concurrently -k \"npx vite\" \"npx wait-on http://localhost:5173 -t 60000 && npx electron .\"",
		"start": "electron .",
		"build:win": "vite build && electron-builder --win --x64",
		"build:linux": "vite build && electron-builder --linux --x64",
		"build:mac": "electron-builder --mac --x64"
	},
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.0.0",
		"electron": "^40.0.0",
		"electron-builder": "^24.4.0",
		"postcss": "^8.4.27",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^3.3.2",
		"vite": "^8.0.3",
		"wait-on": "^8.0.0"
	},
	"dependencies": {
		"electron-context-menu": "^3.6.1",
		"electron-is-dev": "^2.0.0",
		"electron-store": "^8.1.0",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1"
	},
	"build": {
		"appId": "com.stickynotes",
		"productName": "Sticky Notes",
		"files": [
			"src/main/**",
			"dist/renderer/**"
		],
		"linux": {
			"target": "AppImage",
			"icon": "build/icon.png"
		},
		"win": {
			"target": [
				"nsis"
			],
			"icon": "build/icon.ico"
		},
		"mac": {
			"target": [
				"dmg"
			],
			"icon": "build/icon.icns"
		}
	}
}
